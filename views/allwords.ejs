<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>All Words</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <h1>All Words - Alphabetical Order</h1>
    <p>Here are all the words:</p>

    <% words.forEach(function([word, part, definition]) { %>
        <p>
            <b><%= word %></b> - <%= part %> - <%= definition %>
        </p>
        <% }) %>


</body>

</html>